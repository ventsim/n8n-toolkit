{{DOMAIN}} {
    reverse_proxy n8n:{{PORT}} {
        header_up Host {host}
        header_up X-Forwarded-Proto https
    }
}

# IP-based fallback
:80, :443 {
    @ip not host *.*
    handle @ip {
        reverse_proxy n8n:{{PORT}} {
            header_up Host {{DOMAIN}}
            header_up X-Forwarded-Proto {scheme}
        }
    }
}